datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Snapshot {
  id             String   @id @default(cuid())
  shareCode      String   @unique
  sourceUrl      String
  title          String?
  description    String?
  faviconUrl     String?
  htmlPath       String?
  textPath       String?
  screenshotPath String?
  
  // 新增管理与安全属性
  deleteKey      String    @default("")
  sharePassword  String?
  expiresAt      DateTime?
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
