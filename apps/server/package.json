{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "prisma db push && ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "rimraf dist && tsc && pnpm prisma:generate",
    "start": "prisma db push && node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "prisma": "^5.10.2",
    "sanitize-html": "^2.12.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/sanitize-html": "^2.9.5",
    "rimraf": "^5.0.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
